# Adagios configuration — managed by Ansible, do not edit manually
[adagios]
nagios_config = {{ nagios_home }}/etc/nagios.cfg
nagios_binary = {{ nagios_home }}/bin/nagios
nagios_init_script = systemctl
livestatus_path = /var/run/nagios/live
pnp_graph_url = /pnp4nagios/graph
enable_graphite = 0
log_file = /var/log/adagios/adagios.log
