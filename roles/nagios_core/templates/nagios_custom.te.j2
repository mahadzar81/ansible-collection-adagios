module nagios_custom 1.0;

require {
    type httpd_t;
    type nagios_t;
    type nagios_exec_t;
    type nagios_rw_t;
    type nagios_var_run_t;
    type nagios_etc_t;
    type nagios_log_t;
    type nagios_unconfined_plugin_exec_t;
    type httpd_sys_content_t;
    class file { read write execute execute_no_trans open getattr setattr create unlink };
    class dir  { read write search open getattr add_name remove_name };
    class fifo_file { read write open getattr };
    class sock_file { read write open getattr };
    class process { transition signal };
}

# Allow httpd (Apache) to write to the Nagios external command pipe
allow httpd_t nagios_rw_t:fifo_file { read write open getattr };
allow httpd_t nagios_rw_t:file { read write open getattr };

# Allow httpd to read Nagios config and status files
allow httpd_t nagios_etc_t:file { read open getattr };
allow httpd_t nagios_etc_t:dir  { read search open getattr };
allow httpd_t nagios_var_run_t:file { read open getattr };
allow httpd_t nagios_var_run_t:dir  { read search open getattr };

# Allow httpd to execute Nagios CGI scripts
allow httpd_t nagios_exec_t:file { execute execute_no_trans open read getattr };

# Allow Nagios daemon to read its own var/run directory
allow nagios_t nagios_var_run_t:dir  { read write search open getattr add_name remove_name };
allow nagios_t nagios_var_run_t:file { read write open getattr create unlink };

# Allow Nagios to execute plugins from libexec
allow nagios_t nagios_unconfined_plugin_exec_t:file { execute execute_no_trans open read getattr };

# Allow Nagios to write logs
allow nagios_t nagios_log_t:dir  { read write search open getattr add_name remove_name };
allow nagios_t nagios_log_t:file { read write open getattr create };
